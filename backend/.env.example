# Database
DATABASE_URL="mysql://root:password@localhost:3306/borealis"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="your-jwt-secret-change-in-production"
JWT_EXPIRES_IN="7d"

# WeChat Work OAuth
WEWORK_CORP_ID=""
WEWORK_AGENT_ID=""
WEWORK_SECRET=""
WEWORK_REDIRECT_URI=""

# Tencent Cloud COS
COS_SECRET_ID=""
COS_SECRET_KEY=""
COS_BUCKET=""
COS_REGION=""

# Boss role (comma-separated weworkIds for restore access)
BOSS_WEWORK_IDS=

# Sentry (optional -- error tracking disabled when empty)
SENTRY_DSN=

# App
PORT=3000
NODE_ENV="development"

# Storage mode: 'local' for development, 'cos' for production
STORAGE_MODE=local
UPLOAD_DIR=./uploads
BASE_URL=http://localhost:3000
