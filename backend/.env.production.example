# =============================================
# Borealis Fabrics - Production Environment
# =============================================
# Copy this file to .env and fill in all values.
# All variables listed here are REQUIRED in production.

# --- App ---
NODE_ENV="production"
PORT=3000

# --- Database (MySQL 8.0 -- CDB external, not in docker-compose) ---
DATABASE_URL="mysql://user:password@host:3306/borealis"

# --- Redis ---
REDIS_URL="redis://:password@host:6379"

# --- JWT (min 32 characters, must NOT be 'dev-secret') ---
JWT_SECRET="<generate-with: openssl rand -base64 48>"
JWT_EXPIRES_IN="7d"

# --- WeChat Work (WeWork) OAuth ---
WEWORK_CORP_ID="<your-corp-id>"
WEWORK_AGENT_ID="<your-agent-id>"
WEWORK_SECRET="<your-agent-secret>"
WEWORK_REDIRECT_URI="https://your-domain.com/api/v1/auth/wework/callback"

# --- Tencent Cloud COS (Object Storage) ---
COS_SECRET_ID="<your-cos-secret-id>"
COS_SECRET_KEY="<your-cos-secret-key>"
COS_BUCKET="<bucket-name-appid>"
COS_REGION="ap-shanghai"

# --- CORS (comma-separated frontend origins) ---
CORS_ORIGINS="https://your-domain.com"

# --- Storage ---
STORAGE_MODE=cos
UPLOAD_DIR=./uploads
BASE_URL=http://your-server-ip

# --- Monitoring ---
LOKI_HOST=http://loki:3100
SENTRY_DSN=""
SLOW_QUERY_THRESHOLD_MS=200

# --- Boss Role (comma-separated weworkIds for admin access) ---
BOSS_WEWORK_IDS=""

# --- Phase A: Dev Login (remove in Phase B when domain + OAuth is ready) ---
ALLOW_DEV_LOGIN=true

# --- Phase B: HTTPS Cookies (set to true after SSL is configured) ---
# FORCE_HTTPS_COOKIES=true

# --- Docker Compose (if using docker-compose.yml for local MySQL) ---
MYSQL_ROOT_PASSWORD="<strong-password>"
MYSQL_DATABASE="borealis"

# --- Grafana (used by docker-compose.monitoring.yml) ---
GRAFANA_ADMIN_PASSWORD="<strong-password>"
