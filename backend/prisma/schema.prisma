generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================================
// User (Enterprise WeChat OAuth)
// ============================================================
model User {
  id        Int       @id @default(autoincrement())
  weworkId  String    @unique @map("wework_id")
  name      String
  avatar    String?
  mobile    String?
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  orderTimelines OrderTimeline[]
  createdOrders  Order[]          @relation("OrderCreator")
  paymentRecords PaymentRecord[]  @relation("PaymentOperator")

  @@index([deletedAt])
  @@map("users")
}

// ============================================================
// Fabric
// ============================================================
model Fabric {
  id              Int       @id @default(autoincrement())
  fabricCode      String    @map("fabric_code")
  name            String
  material        Json?     @db.Json
  composition     String?
  color           String?
  weight          Decimal?  @db.Decimal(8, 2)
  width           Decimal?  @db.Decimal(8, 2)
  thickness       String?
  handFeel        String?   @map("hand_feel")
  glossLevel      String?   @map("gloss_level")
  application     Json?     @db.Json
  defaultPrice    Decimal?  @map("default_price") @db.Decimal(10, 2)
  defaultLeadTime Int?      @map("default_lead_time")
  description     String?   @db.Text
  tags            Json?     @db.Json
  notes           String?   @db.Text
  deletedAt       DateTime? @map("deleted_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  images          FabricImage[]
  fabricSuppliers FabricSupplier[]
  customerPricing CustomerPricing[]
  orderItems      OrderItem[]
  quoteItems      QuoteItem[]

  @@index([fabricCode])
  @@index([name])
  @@index([color])
  @@index([deletedAt])
  @@map("fabrics")
}

// ============================================================
// Fabric Image
// ============================================================
model FabricImage {
  id        Int      @id @default(autoincrement())
  fabricId  Int      @map("fabric_id")
  url       String
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  fabric Fabric @relation(fields: [fabricId], references: [id], onDelete: Cascade)

  @@index([fabricId])
  @@map("fabric_images")
}

// ============================================================
// File (Generic file storage for COS uploads)
// ============================================================
model File {
  id           Int      @id @default(autoincrement())
  key          String   @unique
  url          String
  originalName String   @map("original_name")
  mimeType     String   @map("mime_type")
  size         Int
  createdAt    DateTime @default(now()) @map("created_at")

  paymentVouchers PaymentVoucher[]

  @@index([key])
  @@index([createdAt])
  @@map("files")
}

// ============================================================
// Supplier
// ============================================================
model Supplier {
  id              Int       @id @default(autoincrement())
  companyName     String    @map("company_name")
  contactName     String?   @map("contact_name")
  phone           String?
  wechat          String?
  email           String?
  address         String?
  status          String    @default("active")
  billReceiveType String?   @map("bill_receive_type")
  settleType      String    @default("prepay") @map("settle_type")
  creditDays      Int?      @map("credit_days")
  notes           String?   @db.Text
  deletedAt       DateTime? @map("deleted_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  fabricSuppliers   FabricSupplier[]
  productSuppliers  ProductSupplier[]
  orderItems        OrderItem[]
  supplierPayments  SupplierPayment[]
  paymentRecords    PaymentRecord[]

  @@index([status])
  @@index([deletedAt])
  @@map("suppliers")
}

// ============================================================
// Fabric-Supplier Association
// ============================================================
model FabricSupplier {
  id            Int      @id @default(autoincrement())
  fabricId      Int      @map("fabric_id")
  supplierId    Int      @map("supplier_id")
  purchasePrice Decimal  @map("purchase_price") @db.Decimal(10, 2)
  minOrderQty   Decimal? @map("min_order_qty") @db.Decimal(10, 2)
  leadTimeDays  Int?     @map("lead_time_days")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  fabric   Fabric   @relation(fields: [fabricId], references: [id], onDelete: Cascade)
  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@unique([fabricId, supplierId])
  @@index([fabricId])
  @@index([supplierId])
  @@map("fabric_suppliers")
}

// ============================================================
// Customer
// ============================================================
model Customer {
  id          Int       @id @default(autoincrement())
  companyName String    @map("company_name")
  contactName String?   @map("contact_name")
  phone       String?
  wechat      String?
  email       String?
  addresses   Json?     @db.Json
  creditType  String    @default("prepay") @map("credit_type")
  creditDays  Int?      @map("credit_days")
  notes       String?   @db.Text
  deletedAt   DateTime? @map("deleted_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  customerPricing CustomerPricing[]
  orders          Order[]
  quotes          Quote[]

  @@index([companyName])
  @@index([deletedAt])
  @@map("customers")
}

// ============================================================
// Customer Pricing
// ============================================================
model CustomerPricing {
  id           Int      @id @default(autoincrement())
  customerId   Int      @map("customer_id")
  fabricId     Int?     @map("fabric_id")
  productId    Int?     @map("product_id")
  specialPrice Decimal  @map("special_price") @db.Decimal(10, 2)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  fabric   Fabric?  @relation(fields: [fabricId], references: [id], onDelete: Cascade)
  product  Product? @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([customerId, fabricId])
  @@unique([customerId, productId])
  @@index([customerId])
  @@index([fabricId])
  @@index([productId])
  @@map("customer_pricing")
}

// ============================================================
// Product
// ============================================================
model Product {
  id            Int       @id @default(autoincrement())
  productCode   String    @map("product_code")
  name          String
  category      String    // "IRON_FRAME_MOTOR" (extensible for future "HARDWARE")
  subCategory   String    @map("sub_category") // "IRON_FRAME" | "MOTOR" | "MATTRESS" | "ACCESSORY"
  modelNumber   String?   @map("model_number")
  specification String?
  defaultPrice  Decimal?  @map("default_price") @db.Decimal(10, 2)
  specs         Json?     @db.Json
  notes         String?   @db.Text
  deletedAt     DateTime? @map("deleted_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  productSuppliers  ProductSupplier[]
  bundleItems       ProductBundleItem[]
  customerPricings  CustomerPricing[]
  orderItems        OrderItem[]
  quoteItems        QuoteItem[]

  @@index([productCode])
  @@index([name])
  @@index([category])
  @@index([subCategory])
  @@index([deletedAt])
  @@map("products")
}

// ============================================================
// Product-Supplier Association
// ============================================================
model ProductSupplier {
  id            Int      @id @default(autoincrement())
  productId     Int      @map("product_id")
  supplierId    Int      @map("supplier_id")
  purchasePrice Decimal  @map("purchase_price") @db.Decimal(10, 2)
  minOrderQty   Decimal? @map("min_order_qty") @db.Decimal(10, 2)
  leadTimeDays  Int?     @map("lead_time_days")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@unique([productId, supplierId])
  @@index([productId])
  @@index([supplierId])
  @@map("product_suppliers")
}

// ============================================================
// Product Bundle
// ============================================================
model ProductBundle {
  id          Int       @id @default(autoincrement())
  bundleCode  String    @map("bundle_code")
  name        String
  description String?   @db.Text
  totalPrice  Decimal?  @map("total_price") @db.Decimal(12, 2)
  deletedAt   DateTime? @map("deleted_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  items ProductBundleItem[]

  @@index([bundleCode])
  @@index([deletedAt])
  @@map("product_bundles")
}

// ============================================================
// Product Bundle Item
// ============================================================
model ProductBundleItem {
  id        Int @id @default(autoincrement())
  bundleId  Int @map("bundle_id")
  productId Int @map("product_id")
  quantity  Int @default(1)

  bundle  ProductBundle @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  product Product       @relation(fields: [productId], references: [id])

  @@unique([bundleId, productId])
  @@index([bundleId])
  @@index([productId])
  @@map("product_bundle_items")
}

// ============================================================
// Order
// ============================================================
model Order {
  id                 Int      @id @default(autoincrement())
  orderCode          String   @unique @map("order_code")
  customerId         Int      @map("customer_id")
  status             String   @default("INQUIRY")
  totalAmount        Decimal  @default(0) @map("total_amount") @db.Decimal(12, 2)

  customerPaid       Decimal  @default(0) @map("customer_paid") @db.Decimal(12, 2)
  customerPayStatus  String   @default("unpaid") @map("customer_pay_status")
  customerPayMethod  String?  @map("customer_pay_method")
  customerCreditDays Int?     @map("customer_credit_days")
  customerPaidAt     DateTime? @map("customer_paid_at")

  deliveryAddress    String?  @map("delivery_address") @db.Text
  createdBy          Int?     @map("created_by")
  notes              String?  @db.Text
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  customer         Customer          @relation(fields: [customerId], references: [id])
  creator          User?             @relation("OrderCreator", fields: [createdBy], references: [id])
  items            OrderItem[]
  supplierPayments SupplierPayment[]
  paymentRecords   PaymentRecord[]

  @@index([orderCode])
  @@index([customerId])
  @@index([status])
  @@index([customerPayStatus])
  @@index([createdAt])
  @@map("orders")
}

// ============================================================
// Order Item
// ============================================================
model OrderItem {
  id            Int      @id @default(autoincrement())
  orderId       Int      @map("order_id")
  fabricId      Int?     @map("fabric_id")
  productId     Int?     @map("product_id")
  supplierId    Int?     @map("supplier_id")
  quoteId       Int?     @map("quote_id")
  quoteItemId   Int?     @map("quote_item_id")
  quantity      Decimal  @map("quantity") @db.Decimal(10, 2)
  unit          String   @default("meter")
  salePrice     Decimal  @map("sale_price") @db.Decimal(10, 2)
  purchasePrice Decimal? @map("purchase_price") @db.Decimal(10, 2)
  subtotal      Decimal  @map("subtotal") @db.Decimal(12, 2)
  status        String   @default("INQUIRY")
  prevStatus    String?  @map("prev_status")
  deliveryDate  DateTime? @map("delivery_date")
  notes         String?  @db.Text
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  order     Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  fabric    Fabric?         @relation(fields: [fabricId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  product   Product?        @relation(fields: [productId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  supplier  Supplier?       @relation(fields: [supplierId], references: [id])
  quote     Quote?          @relation(fields: [quoteId], references: [id])
  quoteItem QuoteItem?      @relation(fields: [quoteItemId], references: [id])
  timelines OrderTimeline[]
  logistics Logistics[]

  @@index([orderId])
  @@index([fabricId])
  @@index([productId])
  @@index([quoteItemId])
  @@index([status])
  @@map("order_items")
}

// ============================================================
// Order Timeline
// ============================================================
model OrderTimeline {
  id          Int      @id @default(autoincrement())
  orderItemId Int      @map("order_item_id")
  fromStatus  String?  @map("from_status")
  toStatus    String   @map("to_status")
  operatorId  Int?     @map("operator_id")
  remark      String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  orderItem OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  operator  User?     @relation(fields: [operatorId], references: [id])

  @@index([orderItemId])
  @@index([createdAt])
  @@map("order_timelines")
}

// ============================================================
// Quote (header-only, items in QuoteItem)
// ============================================================
model Quote {
  id         Int      @id @default(autoincrement())
  quoteCode  String   @unique @map("quote_code")
  customerId Int      @map("customer_id")
  totalPrice Decimal  @map("total_price") @db.Decimal(12, 2)
  validUntil DateTime @map("valid_until")
  status     String   @default("active")
  notes      String?  @db.Text
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  customer   Customer    @relation(fields: [customerId], references: [id])
  items      QuoteItem[]
  orderItems OrderItem[]

  @@index([quoteCode])
  @@index([customerId])
  @@index([validUntil])
  @@index([status])
  @@index([status, validUntil], name: "idx_quotes_status_valid_until")
  @@map("quotes")
}

// ============================================================
// Quote Item
// ============================================================
model QuoteItem {
  id          Int      @id @default(autoincrement())
  quoteId     Int      @map("quote_id")
  fabricId    Int?     @map("fabric_id")
  productId   Int?     @map("product_id")
  quantity    Decimal  @db.Decimal(10, 2)
  unitPrice   Decimal  @map("unit_price") @db.Decimal(10, 2)
  subtotal    Decimal  @db.Decimal(12, 2)
  unit        String   @default("meter")
  isConverted Boolean  @default(false) @map("is_converted")
  notes       String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  quote      Quote       @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  fabric     Fabric?     @relation(fields: [fabricId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  product    Product?    @relation(fields: [productId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  orderItems OrderItem[]

  @@index([quoteId])
  @@index([fabricId])
  @@index([productId])
  @@map("quote_items")
}

// ============================================================
// Logistics
// ============================================================
model Logistics {
  id           Int       @id @default(autoincrement())
  orderItemId  Int       @map("order_item_id")
  carrier      String
  contactName  String?   @map("contact_name")
  contactPhone String?   @map("contact_phone")
  trackingNo   String?   @map("tracking_no")
  shippedAt    DateTime? @map("shipped_at")
  notes        String?   @db.Text
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  orderItem OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@index([orderItemId])
  @@index([trackingNo])
  @@map("logistics")
}

// ============================================================
// Supplier Payment
// ============================================================
model SupplierPayment {
  id         Int       @id @default(autoincrement())
  orderId    Int       @map("order_id")
  supplierId Int       @map("supplier_id")
  payable    Decimal   @default(0) @db.Decimal(12, 2)
  paid       Decimal   @default(0) @db.Decimal(12, 2)
  payStatus  String    @default("unpaid") @map("pay_status")
  payMethod  String?   @map("pay_method")
  creditDays Int?      @map("credit_days")
  paidAt     DateTime? @map("paid_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  supplier Supplier @relation(fields: [supplierId], references: [id])

  @@unique([orderId, supplierId])
  @@index([orderId])
  @@index([supplierId])
  @@index([payStatus])
  @@map("supplier_payments")
}

// ============================================================
// Payment Record (payment flow records)
// ============================================================
model PaymentRecord {
  id         Int      @id @default(autoincrement())
  orderId    Int      @map("order_id")
  type       String                          // customer / supplier
  supplierId Int?     @map("supplier_id")
  amount     Decimal  @db.Decimal(12, 2)
  payMethod  String?  @map("pay_method")
  remark     String?  @db.Text
  operatorId Int?     @map("operator_id")
  createdAt  DateTime @default(now()) @map("created_at")

  order    Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  supplier Supplier? @relation(fields: [supplierId], references: [id])
  operator User?     @relation("PaymentOperator", fields: [operatorId], references: [id])

  vouchers PaymentVoucher[]

  @@index([orderId])
  @@index([supplierId])
  @@index([type])
  @@map("payment_records")
}

// ============================================================
// Payment Voucher (links uploaded files to payment records)
// ============================================================
model PaymentVoucher {
  id              Int      @id @default(autoincrement())
  paymentRecordId Int      @map("payment_record_id")
  fileId          Int      @map("file_id")
  remark          String?  @db.Text
  createdAt       DateTime @default(now()) @map("created_at")

  paymentRecord PaymentRecord @relation(fields: [paymentRecordId], references: [id], onDelete: Cascade)
  file          File          @relation(fields: [fileId], references: [id])

  @@index([paymentRecordId])
  @@index([fileId])
  @@map("payment_vouchers")
}

// ============================================================
// Audit Log (operation audit trail)
// ============================================================
model AuditLog {
  id            Int      @id @default(autoincrement())
  userId        Int?     @map("user_id")
  userName      String   @map("user_name") @db.VarChar(100)
  action        String   @db.VarChar(20)
  entityType    String   @map("entity_type") @db.VarChar(50)
  entityId      Int      @map("entity_id")
  changes       Json     @db.Json
  ip            String   @default("") @db.VarChar(45)
  correlationId String   @default("") @map("correlation_id") @db.VarChar(36)
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([entityType, createdAt])
  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@index([createdAt])
  @@map("audit_logs")
}
